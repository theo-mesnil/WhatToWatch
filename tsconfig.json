{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "~/*": ["./src/*"]
    },
    "types": ["node", "jest", "@testing-library/react-native"],
    "noUnusedParameters": true,
    "noUnusedLocals": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "src/uniwind-types.d.ts"
  ],
  "exclude": ["src/api/types.d.ts"]
}
