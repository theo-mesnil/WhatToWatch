{
  "name": "whattowatch",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "android:build": "eas build --platform android",
    "android:dev": "eas build --profile development-simulator --platform android",
    "android:local": "eas build --profile preview --platform android --local",
    "android:preview": "eas build --profile preview --platform android",
    "android": "expo run:android",
    "dev": "expo start --dev-client",
    "eject": "expo eject",
    "generate:api:types": "npx openapi-typescript openapi/v3.json -o ./src/api/types.d.ts && npx openapi-typescript openapi/v4.json -o ./src/api/types-v4.d.ts && yarn eslint src/api/types.d.ts src/api/types-v4.d.ts  --no-ignore --max-warnings 0 --fix && yarn prettier --write src/api/types.d.ts src/api/types-v4.d.ts ",
    "generate:icons": "npx @svgr/cli -- src/components/Icon/icons && yarn eslint src/components/Icon --max-warnings 0 --fix",
    "ios:build": "eas build --platform ios",
    "ios:dev": "eas build --profile development-simulator --platform ios",
    "ios:local": "eas build --profile preview --platform ios --local",
    "ios:preview": "eas build --profile preview --platform ios",
    "ios": "expo run:ios",
    "lint": "eslint src --max-warnings 0 && tsc --noEmit",
    "pre-release": "eas update --branch pre-release --message",
    "prepare": "husky",
    "preview": "eas update --branch preview --message",
    "start": "expo start",
    "test:ci": "jest --coverage=false --forceExit",
    "test:coverage": "jest",
    "test:e2e": "rm -rf maestro/screenshots && maestro test maestro/",
    "test": "jest --watchAll --coverage=false",
    "translate:extract": "yarn formatjs extract 'src/**/*.ts*' --ignore='**/*.d.ts' --out-file src/locales/temp.json --flatten --format simple",
    "translate": "yarn translate:extract && node ./scripts/translation.js",
    "web": "expo start --web"
  },
  "dependencies": {
    "@expo-google-fonts/poppins": "^0.4.1",
    "@expo/metro-runtime": "~55.0.9",
    "@react-native-masked-view/masked-view": "0.3.2",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-query": "^5.96.2",
    "date-fns": "^4.1.0",
    "expo": "~55.0.11",
    "expo-blur": "~55.0.12",
    "expo-constants": "~55.0.11",
    "expo-dev-client": "~55.0.22",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.11",
    "expo-image": "~55.0.8",
    "expo-linear-gradient": "~55.0.11",
    "expo-linking": "~55.0.11",
    "expo-localization": "~55.0.11",
    "expo-router": "~55.0.10",
    "expo-secure-store": "~55.0.13",
    "expo-splash-screen": "~55.0.15",
    "expo-status-bar": "~55.0.5",
    "expo-updates": "~55.0.18",
    "expo-web-browser": "^55.0.14",
    "intl": "^1.2.5",
    "lodash.merge": "^4.6.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-intl": "^10.1.1",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-webview": "^13.16.1",
    "react-native-youtube-iframe": "^2.3.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^9.39.1",
    "@formatjs/cli": "^6.14.1",
    "@svgr/cli": "^8.1.0",
    "@tanstack/eslint-plugin-query": "^5.96.2",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/lodash.merge": "^4.6.9",
    "@types/node": "^25.5.0",
    "@types/react": "~19.2.10",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-expo": "^1.0.0",
    "eslint-plugin-formatjs": "^6.4.4",
    "eslint-plugin-perfectionist": "^5.8.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.13",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.58.0"
  },
  "private": true
}
